#include <iostream>
#include <windows.h>
#include <mmsystem.h>
#include <string>
#include <vector>

#pragma comment(lib, "winmm.lib") 

using namespace std;

struct LyricLine {
    string text;
    DWORD showAtMs;
};

// Set console text color
void SetColor(int colorCode) {
    HANDLE hConsole = GetStdHandle(STD_OUTPUT_HANDLE);
    SetConsoleTextAttribute(hConsole, colorCode);
}

// Print text with a typewriter effect
void PrintTypewriter(string text, int speedMs) {
    for (int i = 0; i < text.length(); i++) {
        cout << text[i];
        Sleep(speedMs);
    }
    cout << endl;
}

int main() {
    // Note: Update this path if your audio file is located elsewhere
    string filePath = "C:\\Users\\hp\\Music\\sapientdream - Past Lives (Lyrics).wav";

    // Absolute timings ALL shifted by +2000ms based on the first line (7000)
